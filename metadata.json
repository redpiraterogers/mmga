    {<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>MMGA — Make Meditation Great Again</title>
<meta name="description" content="The world's first verified meditation registry. Earn Monk Points. Mint $MONK utility tokens. Gotta sit em all."/>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Instrument+Serif:ital@0;1&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  /* Aggressive Red/White Palette */
  --bg:#0a0a0a;--bg2:#141414;--bg3:#1c1c1c;--bg4:#242424;
  --white:#ffffff;--off:#e8e8e8;--muted:#a0a0a0;--dim:#3a3a3a;--dim2:#4a4a4a;
  --red:#ff0033;--red2:#ff3355;--rdk:#990022;
  --yellow:#ffd700;--ydim:#ccaa00;--ydark:#5a4d00;
  --border:rgba(255,255,255,0.08);--border2:rgba(255,255,255,0.15);--border3:rgba(255,255,255,0.24);
  --shadow:rgba(0,0,0,0.5);
  --px:'Press Start 2P',monospace;
  --serif:'Instrument Serif',Georgia,serif;
  --mono:'DM Mono','Courier New',monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;scroll-padding-top:68px}
body{background:var(--bg);color:var(--white);font-family:var(--mono);overflow-x:hidden;line-height:1.6}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:9998;opacity:0.4}
::selection{background:var(--yellow);color:var(--bg)}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--dim2)}
a{color:inherit}
button,input,textarea,select{font:inherit}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:500;height:64px;display:flex;align-items:center;justify-content:space-between;padding:0 clamp(16px,4vw,40px);background:rgba(15,20,25,0.65);backdrop-filter:blur(16px) saturate(180%);border-bottom:1px solid transparent;transition:all 0.3s ease}
nav.stuck{background:rgba(15,20,25,0.95);border-bottom-color:var(--border3);box-shadow:0 4px 24px rgba(0,0,0,0.12)}
.n-logo{font-family:var(--px);font-size:13px;color:var(--red);text-shadow:2px 2px 0 var(--rdk);text-decoration:none}.n-logo b{color:var(--yellow)}
.n-links{display:flex;list-style:none;gap:4px}
.n-links a{font-size:12px;color:var(--muted);text-decoration:none;padding:8px 14px;transition:all 0.25s ease;letter-spacing:0.02em;border-radius:4px}.n-links a:hover{color:var(--gold);background:rgba(212,165,116,0.08)}
.n-right{display:flex;align-items:center;gap:12px}
.n-cta{font-family:var(--mono);font-size:11px;padding:10px 20px;background:var(--yellow);border:2px solid var(--ydim);border-radius:6px;box-shadow:0 4px 12px rgba(255,215,0,0.3), inset 0 1px 0 rgba(255,255,255,0.2);color:#0a0a0a;font-weight:600;cursor:pointer;text-decoration:none;transition:all 0.25s ease;letter-spacing:0.03em;display:inline-block}.n-cta:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(255,215,0,0.4), inset 0 1px 0 rgba(255,255,255,0.2);background:#ffdd33}
.n-ghost{background:transparent;border-color:var(--border3);box-shadow:none;color:var(--off)}.n-ghost:hover{background:rgba(248,246,240,0.05);border-color:var(--border2)}
.mobile-menu{display:none;background:transparent;color:var(--white);border:1px solid var(--border3);border-radius:4px;font-family:var(--mono);font-size:11px;padding:8px 12px;cursor:pointer;transition:all 0.2s}.mobile-menu:hover{border-color:var(--border2)}
.n-user{font-family:var(--mono);font-size:11px;color:var(--gold);display:flex;align-items:center;gap:10px}
.n-pts{background:rgba(232,192,104,0.1);border:1px solid rgba(232,192,104,0.25);border-radius:4px;padding:6px 12px;font-size:10px;letter-spacing:0.03em}
.n-signout{font-family:var(--mono);font-size:10px;background:transparent;border:1px solid var(--border2);border-radius:4px;color:var(--muted);padding:7px 12px;cursor:pointer;transition:all 0.2s}.n-signout:hover{border-color:var(--yellow);color:var(--yellow)}

/* BUTTONS */
.btn{font-family:var(--px);font-size:10px;padding:14px 32px;display:inline-flex;align-items:center;justify-content:center;gap:10px;cursor:pointer;text-decoration:none;letter-spacing:0.05em;border:3px solid;transition:all 0.15s;text-align:center;line-height:1.4;background:none;text-transform:uppercase}.btn:hover{transform:translate(-2px,-2px)}
.btn-red{background:var(--red);border-color:var(--red2);box-shadow:4px 4px 0 var(--rdk), 6px 6px 0 rgba(0,0,0,0.3);color:var(--white);font-weight:bold}.btn-red:hover{box-shadow:6px 6px 0 var(--rdk), 8px 8px 0 rgba(0,0,0,0.3)}
.btn-yellow{background:var(--yellow);border-color:var(--ydim);box-shadow:4px 4px 0 var(--ydark), 6px 6px 0 rgba(0,0,0,0.3);color:var(--bg);font-weight:bold}.btn-yellow:hover{box-shadow:6px 6px 0 var(--ydark), 8px 8px 0 rgba(0,0,0,0.3)}
.btn-purple{background:var(--red);border-color:var(--red2);box-shadow:4px 4px 0 var(--rdk), 6px 6px 0 rgba(0,0,0,0.3);color:var(--white);font-weight:bold}.btn-purple:hover{box-shadow:6px 6px 0 var(--rdk), 8px 8px 0 rgba(0,0,0,0.3)}
.btn-ghost{background:transparent;border-color:var(--border3);box-shadow:4px 4px 0 var(--dim);color:var(--off)}.btn-ghost:hover{border-color:var(--white);color:var(--white);box-shadow:6px 6px 0 var(--dim)}
.btn-sm{padding:10px 24px;font-size:9px}
.btn-block{display:block;width:100%;text-align:center}

/* LAYOUT */
.s{padding:clamp(80px,10vw,120px) clamp(24px,5vw,48px);max-width:1200px;margin:0 auto}
.s-bg2{background:linear-gradient(180deg, var(--bg2) 0%, var(--bg3) 100%);border-top:2px solid var(--border3);border-bottom:2px solid var(--border3)}
.eyebrow{font-family:var(--px);font-size:9px;color:var(--red);letter-spacing:0.12em;display:block;margin-bottom:20px;text-transform:uppercase;text-shadow:2px 2px 0 var(--dim)}
.s-title{font-family:var(--px);font-size:clamp(18px,3.2vw,28px);margin-bottom:24px;line-height:1.35;max-width:900px;color:var(--white);text-shadow:3px 3px 0 var(--dim), 4px 4px 0 rgba(0,0,0,0.2)}
.s-body{font-family:var(--serif);font-style:italic;font-size:clamp(18px,2.2vw,22px);color:var(--muted);max-width:680px;line-height:1.85}
.s-sub{font-size:14px;color:var(--muted);line-height:1.75;max-width:640px}
hr.thin{border:none;border-top:2px solid var(--border3);max-width:1200px;margin:0 auto;box-shadow:0 1px 0 var(--dim)}

/* HERO */
.hero{min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:140px 32px 96px;position:relative;overflow:hidden;isolation:isolate;background-image:url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&q=80');background-size:cover;background-position:center;background-repeat:no-repeat}
.hero::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg, rgba(10,10,10,0.85) 0%, rgba(10,10,10,0.7) 50%, rgba(10,10,10,0.9) 100%);z-index:0}
.hero > *{position:relative;z-index:1}
.hero-overlay-div{position:absolute;inset:0;pointer-events:none;z-index:0;background:radial-gradient(circle at 80% 20%, rgba(255,0,51,0.15), transparent 50%)}

.h-kicker{font-family:var(--px);font-size:9px;color:var(--yellow);background:rgba(255,215,0,0.12);border:2px solid rgba(255,215,0,0.4);padding:12px 20px;display:inline-block;margin-bottom:32px;letter-spacing:0.1em;line-height:1.6;animation:fadein 0.6s ease both;text-transform:uppercase;box-shadow:3px 3px 0 rgba(90,77,0,0.5)}
@keyframes fadein{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
.h1{font-family:var(--px);font-size:clamp(28px,7vw,72px);color:var(--white);text-shadow:4px 4px 0 var(--dim), 6px 6px 0 rgba(0,0,0,0.3);line-height:1.2;letter-spacing:-0.02em;margin-bottom:8px}
.h2{font-family:var(--px);font-size:clamp(28px,7vw,72px);color:var(--red);text-shadow:4px 4px 0 var(--rdk), 6px 6px 0 rgba(153,0,34,0.4);line-height:1.2;letter-spacing:-0.02em;margin-bottom:8px}
.h-sub{font-family:var(--serif);font-style:italic;font-size:clamp(17px,2.4vw,21px);color:var(--muted);max-width:720px;margin:32px auto 48px;line-height:1.8}
.h-sub strong{font-style:normal;color:var(--off);font-weight:500}
.h-ctas{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-top:8px}
.hero-proof{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:32px}
.proof-pill{font-size:11px;color:var(--muted);border:2px solid var(--border3);padding:8px 16px;background:rgba(248,246,240,0.03);backdrop-filter:blur(8px);transition:all 0.3s;box-shadow:2px 2px 0 var(--dim2)}.proof-pill:hover{border-color:var(--border2);color:var(--off);transform:translate(-1px,-1px);box-shadow:3px 3px 0 var(--dim2)}

/* TICKER */
.ticker{background:var(--yellow);overflow:hidden;padding:14px 0;border-block:3px solid var(--ydim);position:relative;z-index:10;box-shadow:inset 0 2px 0 rgba(255,255,255,0.2), 0 4px 0 rgba(0,0,0,0.2)}
.ticker-t{display:inline-block;white-space:nowrap;animation:tick 40s linear infinite;font-family:var(--px);font-size:9px;color:var(--bg);letter-spacing:0.08em;text-shadow:1px 1px 0 rgba(255,255,255,0.3)}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ROYAL SECRET */
.secret-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;padding:clamp(80px,10vw,120px) clamp(24px,5vw,48px);max-width:1200px;margin:0 auto}
.misconception{background:var(--bg2);border:3px solid var(--border3);border-left:5px solid var(--red);padding:28px;margin-bottom:12px;transition:all 0.3s;box-shadow:4px 4px 0 var(--dim)}.misconception:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--dim)}
.misconception.truth{border-left-color:var(--yellow);border-color:var(--border3)}.misconception.truth:hover{border-left-color:var(--ydim)}
.mis-label{font-family:var(--px);font-size:8px;color:var(--red);margin-bottom:10px;letter-spacing:0.1em;text-transform:uppercase;text-shadow:2px 2px 0 var(--dim)}
.truth .mis-label{color:var(--yellow);text-shadow:2px 2px 0 var(--dim)}
.mis-claim{font-family:var(--serif);font-style:italic;font-size:17px;color:var(--off);margin-bottom:10px;line-height:1.5}
.mis-body{font-size:13px;color:var(--muted);line-height:1.7}

/* TWO RULES */
.rules-bg{background:var(--bg2);border-top:2px solid var(--border2);border-bottom:2px solid var(--border2)}
.rules-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;max-width:1160px;margin:0 auto;background:var(--border2)}
.rule-card{background:var(--bg);padding:clamp(36px,5vw,60px) clamp(24px,4vw,44px);position:relative}
.rule-num{font-family:var(--px);font-size:48px;color:var(--dim);position:absolute;top:20px;right:22px;line-height:1}
.rule-icon{font-size:40px;margin-bottom:18px;display:block}
.rule-title{font-family:var(--px);font-size:clamp(14px,2vw,20px);color:var(--yellow);margin-bottom:14px;text-shadow:1px 1px 0 var(--ydark);line-height:1.4}
.rule-desc{font-family:var(--serif);font-style:italic;font-size:18px;color:var(--off);line-height:1.75;margin-bottom:16px}
.rule-tech{font-size:12px;color:var(--muted);border-left:2px solid var(--dim2);padding-left:12px;line-height:1.65}
.rule-tech strong{color:var(--off)}

/* CALCULATOR */
.calc-section{padding:clamp(64px,8vw,96px) clamp(20px,4vw,40px);background:var(--bg2);border-bottom:2px solid var(--border2)}
.calc-box{max-width:820px;margin:0 auto}
.calc-slider-box{margin:36px 0;padding:clamp(20px,4vw,36px);background:var(--bg);border:2px solid var(--border3);box-shadow:8px 8px 0 var(--dim)}
input[type=range]{width:100%;height:12px;background:var(--bg3);-webkit-appearance:none;appearance:none;outline:none;border:2px solid var(--dim);cursor:pointer;accent-color:var(--yellow)}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:24px;height:24px;background:var(--yellow);border:2px solid var(--ydark);cursor:pointer;box-shadow:2px 2px 0 var(--ydark)}
.calc-result{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:28px}
.res-box{text-align:center;padding:14px;background:rgba(245,242,235,0.03);border:1px solid var(--border)}
.res-val{font-family:var(--px);font-size:clamp(20px,3.5vw,30px);color:var(--yellow);display:block;margin-bottom:6px}
.res-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em}
.privacy-guard{background:rgba(30,215,96,0.05);border:2px dashed rgba(30,215,96,0.3);padding:22px;margin-top:32px;display:flex;align-items:flex-start;gap:16px}

/* STEPS */
.steps-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:2px;margin-top:52px;background:var(--border2);border:2px solid var(--border2)}
.step{background:var(--bg);padding:34px 26px}
.step-n{font-family:var(--px);font-size:8px;color:var(--muted);margin-bottom:14px;letter-spacing:0.1em}
.step-icon{font-size:30px;margin-bottom:14px;display:block}
.step-title{font-family:var(--px);font-size:10px;color:var(--white);margin-bottom:10px;line-height:1.6}
.step-desc{font-size:12px;color:var(--muted);line-height:1.7}

/* SESSIONS */
.sess-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;margin-top:44px}
.sess-card{background:var(--bg2);border:2px solid var(--border);padding:28px;cursor:pointer;transition:all 0.18s;position:relative}
.sess-card:hover{border-color:var(--border3);transform:translateY(-4px);box-shadow:0 16px 40px var(--shadow)}
.sess-ep{font-family:var(--px);font-size:7px;color:var(--muted);margin-bottom:12px;letter-spacing:0.1em}
.sess-icon{font-size:36px;margin-bottom:14px;display:block}
.sess-name{font-family:var(--px);font-size:10px;color:var(--white);margin-bottom:8px;line-height:1.5}
.sess-quote{font-family:var(--serif);font-style:italic;font-size:13px;color:var(--muted);line-height:1.65;margin-bottom:10px}
.sess-locked{position:absolute;top:12px;right:12px;font-family:var(--px);font-size:6px;color:var(--dim2);border:1px solid var(--dim2);padding:3px 8px}

/* VIDEO CARDS */
.video-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;margin-top:44px}
.v-card{background:var(--bg2);border:2px solid var(--border);overflow:hidden;cursor:pointer;transition:all 0.18s}.v-card:hover{border-color:var(--border3);transform:translateY(-4px)}
.v-thumb{aspect-ratio:16/9;background:var(--bg3);display:flex;align-items:center;justify-content:center;position:relative}
.v-thumb-icon{font-size:44px;opacity:0.3}
.v-play{width:52px;height:52px;border-radius:50%;background:rgba(230,51,31,0.9);border:2px solid var(--red2);display:flex;align-items:center;justify-content:center;position:absolute;transition:transform 0.2s}.v-card:hover .v-play{transform:scale(1.1)}
.v-play::after{content:'';width:0;height:0;border-top:9px solid transparent;border-bottom:9px solid transparent;border-left:15px solid white;margin-left:3px}
.v-tag{position:absolute;top:8px;left:8px;font-family:var(--px);font-size:6px;padding:4px 8px;border:1px solid;z-index:2}
.v-tag.free{color:var(--green);border-color:rgba(30,215,96,0.5);background:rgba(30,215,96,0.1)}
.v-tag.pro{color:var(--yellow);border-color:rgba(255,216,77,0.5);background:rgba(255,216,77,0.1)}
.v-dur{position:absolute;bottom:8px;right:8px;font-family:var(--px);font-size:7px;color:var(--white);background:rgba(0,0,0,0.75);padding:3px 7px}
.v-info{padding:20px}
.v-cat{font-family:var(--px);font-size:6px;color:var(--muted);letter-spacing:0.1em;margin-bottom:7px;text-transform:uppercase}
.v-title{font-family:var(--px);font-size:9px;color:var(--white);margin-bottom:7px;line-height:1.5}
.v-desc{font-size:12px;color:var(--muted);line-height:1.65}

/* SCRIPTURES */
.scripture-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:2px;margin-top:36px;background:var(--border)}
.sc-card{background:var(--bg2);padding:28px 22px;transition:background 0.2s;cursor:pointer}.sc-card:hover{background:var(--bg3)}
.sc-tag{font-family:var(--px);font-size:6px;padding:3px 8px;border:1px solid;margin-bottom:12px;display:inline-block;letter-spacing:0.08em}
.sc-icon{font-size:26px;margin-bottom:10px;display:block}
.sc-title{font-family:var(--px);font-size:8px;color:var(--white);margin-bottom:8px;line-height:1.5}
.sc-line{font-family:var(--serif);font-style:italic;font-size:14px;color:var(--muted);line-height:1.65}

/* BOOKING */
.booking-inner{max-width:1160px;margin:0 auto;padding:clamp(64px,8vw,100px) clamp(20px,4vw,40px);display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start}
.monk-card{background:var(--bg);border:2px solid var(--border2);padding:24px;box-shadow:6px 6px 0 var(--dim);display:flex;align-items:center;gap:16px;margin-bottom:24px}
.monk-flame{font-size:44px;animation:float 5s ease-in-out infinite;display:block}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.live-badge{font-family:var(--px);font-size:8px;color:var(--green);display:flex;align-items:center;gap:8px}
.live-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:blink 2s infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}
.monk-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:var(--border)}
.ms{background:var(--bg);padding:14px;text-align:center}
.ms-n{font-family:var(--px);font-size:14px;color:var(--yellow);display:block;margin-bottom:3px;text-shadow:1px 1px 0 var(--ydark)}
.ms-l{font-size:10px;color:var(--muted)}
.f-label{font-family:var(--px);font-size:7px;color:var(--muted);display:block;margin-bottom:6px;letter-spacing:0.1em;text-transform:uppercase}
.f-input{width:100%;background:var(--bg);border:2px solid var(--border2);padding:11px 14px;color:var(--white);outline:none;font-size:13px;transition:border-color 0.2s;margin-bottom:12px}.f-input:focus{border-color:var(--yellow)}.f-input::placeholder{color:var(--dim2)}
.btype{background:var(--bg);border:2px solid var(--border);padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;margin-bottom:2px;transition:border-color 0.1s;width:100%;text-align:left}.btype:hover,.btype.sel{border-color:var(--yellow)}
.btype-name{font-family:var(--px);font-size:8px;color:var(--white);margin-bottom:3px}
.btype-desc{font-size:11px;color:var(--muted)}
.btype-price{font-family:var(--px);font-size:9px;color:var(--yellow);white-space:nowrap;margin-left:10px;flex-shrink:0}
.book-success{display:none;background:rgba(30,215,96,0.08);border:2px solid rgba(30,215,96,0.3);padding:20px;text-align:center;margin-top:12px}.book-success.show{display:block}

/* COMPANIES */
.dash{background:var(--bg);border:3px solid var(--border3);box-shadow:8px 8px 0 var(--dim);overflow:hidden}
.dash-bar{background:var(--bg3);padding:13px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.dash-t{font-family:var(--px);font-size:7px;color:var(--muted);letter-spacing:0.08em}
.dash-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:2px;background:var(--border)}
.ds{background:var(--bg2);padding:22px;text-align:center}
.ds-n{font-family:var(--px);font-size:22px;color:var(--yellow);margin-bottom:4px;text-shadow:1px 1px 0 var(--ydark)}
.ds-l{font-size:11px;color:var(--muted);letter-spacing:0.06em}
.dt-head{display:grid;grid-template-columns:2fr 1fr 1fr;background:var(--bg3);padding:10px 18px}
.dt-th{font-family:var(--px);font-size:6px;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase}
.dt-row{display:grid;grid-template-columns:2fr 1fr 1fr;padding:11px 18px;border-top:1px solid var(--border);align-items:center}.dt-row:hover{background:var(--bg2)}
.dt-c{font-size:12px;color:var(--off)}
.dt-badge{font-family:var(--px);font-size:5px;padding:3px 7px;border:1px solid}
.dt-badge.g{border-color:var(--green);color:var(--green)}
.dt-badge.y{border-color:var(--yellow);color:var(--yellow)}
.impact-box{background:var(--bg);border:2px solid var(--border2);padding:32px;box-shadow:6px 6px 0 var(--dim)}
.impact-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--dim);gap:16px}.impact-row:last-child{border-bottom:none}
.impact-lbl{font-size:12px;color:var(--muted)}
.impact-val{font-family:var(--px);font-size:9px;color:var(--yellow)}
.impact-total{font-family:var(--px);font-size:9px;color:var(--green);text-align:center;margin-top:14px;line-height:1.8;padding-top:14px;border-top:2px solid var(--yellow)}

/* MONK TOKEN SECTION */
.monk-token-bg{background:radial-gradient(ellipse at center,rgba(157,78,221,0.08),transparent 60%),var(--bg);border-top:2px solid var(--border2);border-bottom:2px solid var(--border2)}
.epoch-countdown{background:var(--bg);border:3px solid var(--purple);padding:clamp(24px,4vw,40px);box-shadow:8px 8px 0 var(--pdim);margin-top:40px}
.epoch-timer{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;background:var(--border);margin-top:20px}
.epoch-unit{background:var(--bg2);padding:20px;text-align:center}
.epoch-num{font-family:var(--px);font-size:clamp(24px,4vw,40px);color:var(--purple);display:block;margin-bottom:6px}
.epoch-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em}
.soulbound-box{background:var(--bg);border:2px solid var(--border2);padding:28px;margin-top:32px}
.sb-row{display:flex;gap:16px;align-items:flex-start;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid var(--dim)}.sb-row:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
.sb-icon{font-size:28px;flex-shrink:0}
.sb-text h4{font-family:var(--px);font-size:9px;color:var(--white);margin-bottom:6px;line-height:1.5}
.sb-text p{font-size:12px;color:var(--muted);line-height:1.65}

/* LEADERBOARD */
.lb-box{background:var(--bg2);border:2px solid var(--border2);overflow:hidden;box-shadow:6px 6px 0 var(--dim)}
.lb-hd{background:var(--bg3);padding:14px 22px;border-bottom:2px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.lb-row{display:flex;align-items:center;gap:14px;padding:13px 22px;border-bottom:1px solid var(--border)}.lb-row:last-child{border-bottom:none}.lb-row:hover{background:var(--bg3)}
.lb-pos{font-family:var(--px);font-size:9px;color:var(--dim2);width:28px;flex-shrink:0}.lb-pos.gold{color:var(--yellow)}
.lb-flag{font-size:18px;flex-shrink:0}
.lb-name{font-size:12px;color:var(--off);flex:1}
.lb-bar{width:80px;height:3px;background:var(--dim);overflow:hidden;flex-shrink:0}
.lb-fill{height:100%;background:var(--yellow)}
.lb-pts{font-family:var(--px);font-size:8px;color:var(--yellow);flex-shrink:0}

/* PRICING */
.price-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:2px;background:var(--border2);border:2px solid var(--border2);margin-top:44px}
.p-card{background:var(--bg2);padding:40px 28px;position:relative}
.p-card.star{background:var(--bg3);border:2px solid var(--yellow)}
.p-star{position:absolute;top:-2px;left:50%;transform:translateX(-50%);font-family:var(--px);font-size:6px;background:var(--yellow);color:var(--bg);padding:4px 14px;white-space:nowrap;letter-spacing:0.08em}
.p-tier{font-family:var(--px);font-size:8px;color:var(--red);margin-bottom:18px;letter-spacing:0.1em}
.p-num{font-family:var(--px);font-size:32px;color:var(--white);margin-bottom:4px;text-shadow:3px 3px 0 var(--dim)}
.p-per{font-size:12px;color:var(--muted);margin-bottom:22px}
.p-feats{list-style:none;display:flex;flex-direction:column;gap:9px;margin-bottom:24px}
.p-feats li{font-size:12px;color:var(--muted);display:flex;gap:8px;align-items:flex-start;line-height:1.5}
.p-feats li::before{content:'→';color:var(--dim2);flex-shrink:0}
.p-feats li.on{color:var(--off)}.p-feats li.on::before{content:'✓';color:var(--green)}
.p-btn{display:block;width:100%;text-align:center;font-family:var(--px);font-size:7px;padding:12px;background:transparent;border:2px solid var(--border3);box-shadow:3px 3px 0 var(--dim);color:var(--off);cursor:pointer;transition:all 0.1s;text-decoration:none;letter-spacing:0.06em}.p-btn:hover{border-color:var(--white);color:var(--white);transform:translate(-1px,-1px)}
.p-btn.main{background:var(--red);border-color:var(--red2);box-shadow:3px 3px 0 var(--rdk);color:var(--white)}.p-btn.main:hover{box-shadow:5px 5px 0 var(--rdk)}

/* SUGGEST */
.suggest-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:10px;margin-top:36px}
.sg{background:var(--bg2);border:1px solid var(--border2);padding:22px;transition:border-color 0.2s}.sg:hover{border-color:var(--border3)}
.sg-icon{font-size:24px;margin-bottom:10px;display:block}
.sg-title{font-family:var(--px);font-size:8px;color:var(--white);margin-bottom:7px;line-height:1.5}
.sg-desc{font-size:12px;color:var(--muted);line-height:1.65}
.sg-tag{display:inline-block;margin-top:8px;font-family:var(--px);font-size:5px;padding:3px 7px;border:1px solid var(--dim2);color:var(--muted)}

/* DISCLAIMER */
.disclaimer-box{background:rgba(230,51,31,0.05);border:2px dashed rgba(230,51,31,0.3);padding:clamp(20px,4vw,32px);margin-top:clamp(60px,8vw,100px);max-width:1160px;margin-left:auto;margin-right:auto}
.disclaimer-box h4{font-family:var(--px);font-size:9px;color:var(--red);margin-bottom:14px;letter-spacing:0.08em}
.disclaimer-box p{font-size:12px;color:var(--muted);line-height:1.75;margin-bottom:12px}
.disclaimer-box p:last-child{margin-bottom:0}

/* AUTH MODAL */
.auth-modal{position:fixed;inset:0;z-index:900;background:rgba(11,11,9,0.97);backdrop-filter:blur(10px);display:none;align-items:center;justify-content:center;padding:20px}
.auth-modal.open{display:flex}
.auth-box{width:100%;max-width:440px;background:var(--bg2);border:2px solid var(--border3);box-shadow:12px 12px 0 var(--dim);padding:40px;position:relative}
.auth-close{position:absolute;top:16px;right:16px;font-family:var(--px);font-size:8px;background:none;border:1px solid var(--border2);color:var(--muted);padding:6px 10px;cursor:pointer}.auth-close:hover{border-color:var(--red);color:var(--red)}
.auth-logo{font-family:var(--px);font-size:14px;color:var(--red);text-shadow:2px 2px 0 var(--rdk);margin-bottom:8px;display:block}.auth-logo b{color:var(--yellow)}
.auth-tag{font-family:var(--serif);font-style:italic;font-size:15px;color:var(--muted);display:block;margin-bottom:28px}
.auth-input{width:100%;background:var(--bg);border:2px solid var(--border2);padding:14px 16px;color:var(--white);font-family:var(--mono);font-size:14px;outline:none;margin-bottom:12px;transition:border-color 0.2s}.auth-input:focus{border-color:var(--yellow)}.auth-input::placeholder{color:var(--dim2)}
.auth-btn{width:100%;font-family:var(--px);font-size:9px;padding:14px;background:var(--red);border:2px solid var(--red2);box-shadow:3px 3px 0 var(--rdk);color:var(--white);cursor:pointer;letter-spacing:0.06em;transition:all 0.1s;margin-bottom:12px}.auth-btn:hover{transform:translate(-1px,-1px)}.auth-btn:disabled{opacity:0.4;cursor:not-allowed;transform:none}
.auth-divider{display:flex;align-items:center;gap:12px;margin:14px 0;color:var(--dim2);font-size:11px}.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--border)}
.auth-google{width:100%;font-family:var(--px);font-size:9px;padding:14px;background:transparent;border:2px solid var(--border3);box-shadow:3px 3px 0 var(--dim);color:var(--off);cursor:pointer;letter-spacing:0.06em;transition:all 0.1s;display:flex;align-items:center;justify-content:center;gap:10px}.auth-google:hover{border-color:var(--white);color:var(--white)}
.auth-msg{font-family:var(--px);font-size:8px;text-align:center;line-height:1.8;padding:10px;min-height:36px}
.auth-msg.ok{color:var(--green);background:rgba(30,215,96,0.08);border:1px solid rgba(30,215,96,0.2)}
.auth-msg.err{color:var(--red);background:rgba(230,51,31,0.08);border:1px solid rgba(230,51,31,0.2)}
.auth-note{font-size:11px;color:var(--muted);text-align:center;margin-top:14px;line-height:1.6}

/* CAMERA MODAL */
.cam-modal{position:fixed;inset:0;z-index:1000;background:rgba(11,11,9,0.96);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;padding:20px}
.cam-modal.open{display:flex}
.cam-inner{width:100%;max-width:900px;background:var(--bg2);border:2px solid var(--border3);box-shadow:12px 12px 0 var(--dim);overflow:hidden;max-height:95svh;overflow-y:auto;display:flex;flex-direction:column}
.cam-top{background:var(--bg3);padding:14px 20px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid var(--border2);position:sticky;top:0;z-index:5}
.cam-top-title{font-family:var(--px);font-size:9px;color:var(--yellow);letter-spacing:0.06em}
.cam-close-btn{font-family:var(--px);font-size:8px;background:none;border:2px solid var(--border3);color:var(--muted);padding:7px 12px;cursor:pointer;transition:all 0.1s}.cam-close-btn:hover{border-color:var(--red);color:var(--red)}
.cam-body{display:grid;grid-template-columns:1fr 320px}
.cam-left{padding:24px;border-right:2px solid var(--border)}
.cam-right{padding:24px;display:flex;flex-direction:column;gap:14px}
.cam-wrap{position:relative;aspect-ratio:4/3;background:#000;border:2px solid var(--border2);overflow:hidden}
.cam-wrap video,.cam-wrap canvas{position:absolute;inset:0;width:100%;height:100%;transform:scaleX(-1)}
.cam-overlay-status{position:absolute;top:10px;left:10px;right:10px;z-index:5;display:flex;justify-content:space-between}
.status-pill{font-family:var(--px);font-size:7px;padding:5px 10px;border:2px solid;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px)}
.sp-ok{border-color:var(--green);color:var(--green)}
.sp-fail{border-color:var(--red);color:var(--red)}
.sp-wait{border-color:var(--muted);color:var(--muted)}
.cam-glow{position:absolute;inset:-2px;border:3px solid var(--green);z-index:3;opacity:0;transition:opacity 0.4s;pointer-events:none;box-shadow:0 0 20px var(--green)}
.cam-glow.on{opacity:1}
.pts-big{font-family:var(--px);font-size:28px;color:var(--yellow);text-shadow:2px 2px 0 var(--ydark);text-align:center;display:block}
.pts-lbl{font-family:var(--px);font-size:7px;color:var(--muted);text-align:center;display:block;margin-top:4px;letter-spacing:0.08em}
.timer-box{background:var(--bg);border:2px solid var(--border2);padding:14px;text-align:center}
.timer-big{font-family:var(--px);font-size:22px;color:var(--white)}
.timer-big.counting{color:var(--green)}
.prog-track{height:6px;background:var(--bg);border:1px solid var(--dim);overflow:hidden;margin-top:8px}
.prog-fill{height:100%;background:var(--yellow);width:0;transition:width 0.5s linear}
.prog-fill.earn{background:var(--green)}
.med-banner{background:rgba(30,215,96,0.08);border:2px solid rgba(30,215,96,0.3);padding:10px 14px;text-align:center;display:none}
.med-banner.on{display:block}
.guest-banner{background:rgba(255,216,77,0.08);border-bottom:1px solid rgba(255,216,77,0.2);padding:10px 20px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}

/* SIGNUP */
.signup-bg{background:radial-gradient(ellipse at center,rgba(230,51,31,0.1),transparent 60%),var(--bg);padding:clamp(80px,10vw,120px) 20px;text-align:center;border-top:2px solid var(--border2)}

/* FOOTER */
footer{background:var(--bg2);border-top:2px solid var(--border2);padding:56px 40px 36px}
.footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:40px;max-width:1160px;margin:0 auto 40px}
.f-logo{font-family:var(--px);font-size:13px;color:var(--red);text-shadow:2px 2px 0 var(--rdk);display:block;margin-bottom:12px}.f-logo b{color:var(--yellow)}
.f-about{font-size:12px;color:var(--muted);line-height:1.7;max-width:220px}
.f-col-h{font-family:var(--px);font-size:7px;color:var(--muted);letter-spacing:0.12em;margin-bottom:14px;display:block}
.f-links{list-style:none;display:flex;flex-direction:column;gap:8px}
.f-links a{font-size:12px;color:var(--muted);text-decoration:none;transition:color 0.2s}.f-links a:hover{color:var(--yellow)}
.f-bottom{max-width:1160px;margin:0 auto;border-top:1px solid var(--border);padding-top:20px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
.f-copy{font-size:11px;color:var(--dim2)}
.f-tag{font-family:var(--px);font-size:7px;color:var(--dim2)}

/* POINT POP */
.point-pop{position:fixed;top:72px;left:50%;transform:translateX(-50%);z-index:2000;font-family:var(--px);font-size:11px;background:var(--yellow);color:var(--bg);padding:11px 28px;border:2px solid white;box-shadow:4px 4px 0 var(--ydark);pointer-events:none;opacity:0;transition:opacity 0.3s;white-space:nowrap}
.point-pop.on{opacity:1}

/* REVEAL */
.reveal{opacity:0;transform:translateY(20px);transition:all 0.6s ease-out}
.reveal.active{opacity:1;transform:none}

/* RESPONSIVE */
@media(max-width:980px){
  .n-links{display:none;position:absolute;top:100%;left:0;right:0;background:rgba(11,11,9,0.98);border-bottom:1px solid var(--border2);padding:12px 16px;flex-direction:column}
  .n-links.open{display:flex}
  .mobile-menu{display:block}
  .n-right .n-ghost{display:none}
  .rules-grid,.booking-inner,.secret-grid{grid-template-columns:1fr}
  .cam-body{grid-template-columns:1fr}.cam-left{border-right:none;border-bottom:2px solid var(--border)}
  .footer-grid{grid-template-columns:1fr 1fr;gap:28px}
  .epoch-timer{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:640px){
  .h-ctas .btn,.h-ctas button{width:100%}
  .calc-result{grid-template-columns:1fr}
  .footer-grid{grid-template-columns:1fr}
  .cam-inner{max-height:100svh}
  .epoch-timer{grid-template-columns:1fr}
}
</style>
</head>
<body>

<div class="point-pop" id="pointPop">+1 MONK POINT ★</div>


<!-- NAV -->
<nav id="nav">
  <a href="index.html" class="n-logo">M<b>M</b>GA</a>
  <button class="mobile-menu" id="mobileMenu" type="button">Menu</button>
  <ul class="n-links" id="navLinks">
    <li><a href="info.html">Learn More</a></li>
  </ul>
  <div class="n-right" id="navRight">
    <button id="nav-wallet-btn" class="n-cta" onclick="window.navConnectWallet()">Connect Wallet</button>
    <div id="nav-wallet-connected" style="display:none;font-family:var(--mono);font-size:11px;color:var(--yellow);padding:8px 16px;background:rgba(255,215,0,0.1);border:2px solid rgba(255,215,0,0.3);border-radius:4px;">
      <span id="nav-wallet-address"></span>
    </div>
  </div>
</nav>

<!-- Mobile Browser Warning -->
<div id="mobile-browser-warning" style="display:none;background:#ff0033;color:#fff;padding:12px 20px;text-align:center;font-family:var(--mono);font-size:11px;line-height:1.5">
  ⚠️ For best experience, open this page in Safari or Chrome instead of the Phantom in-app browser
</div>


<!-- MAIN CONTENT -->
<div class="s" style="padding-top:120px;max-width:900px;margin:0 auto">
  
  <h1 style="font-family:var(--px);font-size:42px;color:var(--red);margin-bottom:48px;text-align:center;letter-spacing:0.05em">
    ⚔ MEDITATION SESSION
  </h1>
  
  <!-- THE TWO RULES -->
  <div style="margin-bottom:48px">
    <h2 style="font-family:var(--px);font-size:28px;color:var(--yellow);margin-bottom:32px;text-align:center">THE TWO RULES</h2>
    
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:32px">
      
      <!-- Rule 1 -->
      <div style="background:var(--bg2);border:2px solid var(--border3);padding:32px">
        <div style="font-family:var(--px);font-size:48px;color:var(--yellow);margin-bottom:16px">01</div>
        <div style="font-family:var(--px);font-size:20px;color:var(--red);margin-bottom:12px;letter-spacing:0.05em">SPINE ERECT</div>
        <p style="font-size:14px;color:var(--muted);line-height:1.6">
          Nose above shoulders. Not rigid, not slouched. Your skeleton knows the position.
        </p>
      </div>
      
      <!-- Rule 2 -->
      <div style="background:var(--bg2);border:2px solid var(--border3);padding:32px">
        <div style="font-family:var(--px);font-size:48px;color:var(--yellow);margin-bottom:16px">02</div>
        <div style="font-family:var(--px);font-size:20px;color:var(--red);margin-bottom:12px;letter-spacing:0.05em">EYES CLOSED</div>
        <p style="font-size:14px;color:var(--muted);line-height:1.6">
          Close your eyes. Not squeezed shut, not peeking. This cuts 80% of sensory input.
        </p>
      </div>
      
    </div>
    
    <!-- Earning Rate -->
    <div style="background:rgba(255,215,0,0.05);border:2px solid var(--border3);padding:24px;text-align:center">
      <div style="font-family:var(--mono);font-size:11px;color:var(--dim);margin-bottom:8px">EARNING RATE</div>
      <div style="font-family:var(--px);font-size:32px;color:var(--yellow);margin-bottom:8px">1 $MONK PER SECOND</div>
      <p style="font-size:13px;color:var(--muted)">Hold both rules verified = earn tokens</p>
    </div>
  </div>
  
  <!-- BIOMETRIC DISCLAIMER -->
  <div style="background:var(--bg3);border:2px solid var(--border);padding:32px;margin-bottom:48px">
    <div style="font-family:var(--mono);font-size:11px;color:var(--dim);margin-bottom:16px;letter-spacing:0.1em">⚠️ BIOMETRIC DATA COMPLIANCE</div>
    
    <p style="font-size:14px;color:var(--muted);line-height:1.7;margin-bottom:16px">
      This application uses your device camera to detect posture (spine alignment) and eye closure status using 
      Google MediaPipe AI. <strong style="color:var(--off)">All processing happens locally in your browser.</strong>
    </p>
    
    <p style="font-size:14px;color:var(--muted);line-height:1.7;margin-bottom:16px">
      <strong style="color:var(--off)">No video or images are recorded, stored, or transmitted.</strong> 
      No biometric data leaves your device. The camera feed is processed in real-time and immediately discarded.
    </p>
    
    <p style="font-size:14px;color:var(--muted);line-height:1.7">
      By clicking "BEGIN SESSION" you consent to local camera access for posture verification purposes only.
      You can revoke camera access at any time through your browser settings.
    </p>
  </div>
  
  <!-- BEGIN SESSION BUTTON -->
  <div style="text-align:center;margin-bottom:80px">
    <button onclick="openCam()" class="btn" style="background:var(--red);color:#fff;padding:32px 64px;font-size:28px;font-weight:700;box-shadow:8px 8px 0 var(--rdk);font-family:var(--px);cursor:pointer;border:none;letter-spacing:0.05em">
      ⚔ BEGIN SESSION
    </button>
    <p style="font-family:var(--mono);font-size:11px;color:var(--dim);margin-top:16px">
      CAMERA ACCESS REQUIRED · FREE FOREVER
    </p>
  </div>
  
  <!-- MINT WIDGET -->
  <div id="mmga-mint-widget" style="max-width:600px;margin:0 auto 80px;background:var(--bg2);border:2px solid var(--border3);padding:48px">
    
    <h2 style="font-family:var(--px);font-size:28px;color:var(--yellow);margin-bottom:32px;text-align:center;letter-spacing:0.05em">
      💰 MINT YOUR $MONK
    </h2>
    
    <!-- Wallet Section -->
    <div id="mmga-wallet-section">
      <div style="text-align:center;padding:24px;background:var(--bg3);border:2px solid var(--border);font-family:var(--mono);font-size:14px;color:var(--muted);margin-bottom:16px">
        🔗 CONNECT WALLET TO VIEW BALANCE
      </div>
      <button onclick="connectWallet()" style="background:var(--yellow);color:var(--bg);border:none;padding:16px 32px;font-family:var(--px);font-size:14px;font-weight:700;cursor:pointer;display:block;margin:0 auto;width:100%;letter-spacing:0.05em">
        CONNECT WALLET
      </button>
    </div>
    
    <!-- Balance Display -->
    <div id="mmga-balance-section"></div>
    
    <!-- Mint Controls -->
