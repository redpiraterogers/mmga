<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>

<script>
/* NAV */
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => nav.classList.toggle('stuck', scrollY > 20), {passive:true});
document.getElementById('mobileMenu').addEventListener('click', () => document.getElementById('navLinks').classList.toggle('open'));
document.getElementById('navLinks').querySelectorAll('a').forEach(a => a.addEventListener('click', () => document.getElementById('navLinks').classList.remove('open')));

/* SCROLL REVEAL */
const revealObs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('active'); });
}, {threshold: 0.1});
document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

/* CALCULATOR */
const sl = document.getElementById('minSlider');
if (sl) {
  sl.addEventListener('input', () => {
    const v = Number(sl.value);
    document.getElementById('rTime').textContent = v + 'm';
    document.getElementById('rWeek').textContent = (v*7) + ' $MONK';
    document.getElementById('rRank').textContent = v<10?'Seeker':v<20?'Initiate':v<35?'Adept':v<50?'Monk':'Void Master';
  });
}

/* EPOCH COUNTDOWN */
function updateEpochCountdown() {
  const now = new Date();
  const epoch = new Date('2030-01-01T00:00:00Z');
  const diff = epoch - now;
  if (diff > 0) {
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const years = Math.floor(days / 365);
    const months = Math.floor((days % 365) / 30);
    const daysRem = days % 30;
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    if(document.getElementById('epochYears')) {
      document.getElementById('epochYears').textContent = years;
      document.getElementById('epochMonths').textContent = months;
      document.getElementById('epochDays').textContent = daysRem;
      document.getElementById('epochHours').textContent = hours;
    }
  }
}
updateEpochCountdown();
setInterval(updateEpochCountdown, 3600000); // Update every hour

/* CAMERA */
let spineOk = false, eyesOk = false, sessActive = false, sessTimer = null, consec = 0, sessElapsed = 0;
let totalPts = parseInt(localStorage.getItem('mmga_pts') || '0');
let faceMesh, pose, localStream;
let latestFace = null, latestPose = null;
let camLoopActive = false; // Added to cleanly control camera animation frame

if(document.getElementById('modalPts')) document.getElementById('modalPts').textContent = totalPts;

async function startCam() {
  camLoopActive = false;
  document.getElementById('camPerm').style.display = 'none';
  document.getElementById('loadFill').style.width = '30%';
  
  // Detect mobile
  const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
  
  // Check if camera is supported
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    document.getElementById('camPerm').style.display = 'flex';
    document.getElementById('camPerm').innerHTML = `
      <div style="font-size:36px">⚠</div>
      <div style="font-family:var(--px);font-size:9px">CAMERA NOT SUPPORTED</div>
      <p style="font-size:12px;color:var(--muted);max-width:280px;line-height:1.7;margin-top:12px">
        This browser doesn't support camera access. 
        <strong style="color:var(--off)">Open this page in Safari or Chrome</strong> instead of the Phantom in-app browser.
      </p>
      <a href="${window.location.href}" target="_blank" style="margin-top:16px;padding:10px 20px;background:var(--red);color:#fff;text-decoration:none;font-family:var(--px);font-size:8px;border-radius:4px;">
        OPEN IN SAFARI/CHROME →
      </a>
    `;
    return;
  }
  
  try {
    const constraints = isMobile ? {
      video: {
        facingMode: 'user',
        width: { ideal: 640 },
        height: { ideal: 480 }
      }
    } : {
      video: {
        width: { ideal: 640 },
        height: { ideal: 480 },
        facingMode: 'user'
      }
    };
    
    console.log('Requesting camera with constraints:', constraints);
    localStream = await navigator.mediaDevices.getUserMedia(constraints);
    console.log('Camera stream obtained!');
    
    const videoEl = document.getElementById('camVideo');
    videoEl.srcObject = localStream;
    
    // Wait for video to be ready
    videoEl.onloadedmetadata = () => {
      console.log('Video metadata loaded, starting playback');
      videoEl.play().then(() => {
        console.log('Video playing, initializing detection');
        initDetection();
      }).catch(err => {
        console.error('Video play error:', err);
        addLog('Video play error: ' + err.message);
      });
    };
    
  } catch(e) {
    console.error('Camera error:', e);
    document.getElementById('camPerm').style.display = 'flex';
    
    // Better error messages based on error type
    let errorMsg = 'Allow camera access in your browser settings and refresh.';
    let errorTitle = 'Camera denied';
    
    if (e.name === 'NotAllowedError') {
      errorTitle = 'Camera permission denied';
      errorMsg = isMobile 
        ? 'Tap the AA button (Safari) or lock icon (Chrome) in the address bar, then enable Camera and refresh this page.'
        : 'You blocked camera access. Go to your browser settings, allow camera for this site, and refresh.';
    } else if (e.name === 'NotFoundError') {
      errorTitle = 'No camera found';
      errorMsg = 'No camera detected on your device. Make sure a camera is connected.';
    } else if (e.name === 'NotSupportedError') {
      errorTitle = 'Browser not supported';
      errorMsg = 'This browser doesn\'t support camera access. Try opening in Safari or Chrome instead.';
    } else if (e.name === 'NotReadableError') {
      errorTitle = 'Camera in use';
      errorMsg = 'Your camera is being used by another app. Close other apps and try again.';
    } else if (e.name === 'OverconstrainedError') {
      errorTitle = 'Camera constraints not supported';
      errorMsg = 'Your camera doesn\'t support the required resolution. Try a different device.';
    }
    
    document.getElementById('camPerm').innerHTML = `
      <div style="font-size:36px">⚠</div>
      <div style="font-family:var(--px);font-size:9px">${errorTitle.toUpperCase()}</div>
      <p style="font-size:12px;color:var(--muted);max-width:280px;line-height:1.7;margin-top:12px">${errorMsg}</p>
      <div style="margin-top:12px;font-size:10px;color:#666;font-family:monospace;">Error: ${e.name}</div>
    `;
  }
}

function initDetection() {
  const videoEl = document.getElementById('camVideo');
  
  // Mobile-specific: ensure video is playing
  const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
  if (isMobile) {
    videoEl.setAttribute('playsinline', 'true');
    videoEl.setAttribute('autoplay', 'true');
    videoEl.setAttribute('muted', 'true');
  }
  
  if (!faceMesh) {
    faceMesh = new FaceMesh({locateFile: f => `https://cdn.jsdelivr.net/npm/@mediapipe/face_mesh@0.4/${f}`});
    faceMesh.setOptions({maxNumFaces:1, refineLandmarks:true, minDetectionConfidence:0.5});
    faceMesh.onResults(r => { latestFace = r; checkLogic(); });
  }

  if (!pose) {
    pose = new Pose({locateFile: f => `https://cdn.jsdelivr.net/npm/@mediapipe/pose@0.5/${f}`});
    pose.setOptions({modelComplexity:1, minDetectionConfidence:0.5});
    pose.onResults(r => { latestPose = r; checkLogic(); });
  }

  document.getElementById('loadFill').style.width = '100%';
  document.getElementById('camStatusBar').style.display = 'flex';
  document.getElementById('sessBtn').disabled = false;
  addLog('Detection active. Ready to mint $MONK.');

  camLoopActive = true;
  let isProcessing = false;

  async function detectionLoop() {
    if (!camLoopActive) return;

    // Process only if we have sufficient video data and previous frame has finished
    if (videoEl.readyState >= 2 && !isProcessing) {
      isProcessing = true;
      try {
        if (faceMesh) await faceMesh.send({image: videoEl});
        if (pose) await pose.send({image: videoEl});
        drawVisuals();
      } catch (e) {
        console.error("Frame processing error:", e);
      }
      isProcessing = false;
    }
    requestAnimationFrame(detectionLoop);
  }
  
  detectionLoop();
}

function checkLogic() {
  if (latestFace?.multiFaceLandmarks?.[0]) {
    const lm = latestFace.multiFaceLandmarks[0];
    const LE = [33,160,158,133,153,144], RE = [362,385,387,263,373,380];
    const d = (a,b) => Math.hypot(lm[a].x-lm[b].x, lm[a].y-lm[b].y);
    const ear = idx => (d(idx[1],idx[5]) + d(idx[2],idx[4])) / (2*d(idx[0],idx[3]));
    const newEyes = ((ear(LE) + ear(RE)) / 2) < 0.22;
    if (newEyes !== eyesOk) { eyesOk = newEyes; updateRule('eyes', eyesOk); }
  }
  if (latestPose?.poseLandmarks) {
    const lm = latestPose.poseLandmarks;
    const shoulderY = (lm[11].y + lm[12].y) / 2;
    const newSpine = lm[0].y < shoulderY;
    if (newSpine !== spineOk) { spineOk = newSpine; updateRule('spine', spineOk); }
  }
  document.getElementById('medBanner').classList.toggle('on', sessActive && spineOk && eyesOk);
  document.getElementById('camGlow').classList.toggle('on', sessActive && spineOk && eyesOk);
}

function updateRule(type, ok) {
  const isSpine = type === 'spine';
  const icon = document.getElementById(isSpine ? 'ruleSpineIcon' : 'ruleEyesIcon');
  const box = document.getElementById(isSpine ? 'ruleSpineBox' : 'ruleEyesBox');
  const pill = document.getElementById(isSpine ? 'spineStatusPill' : 'eyesStatusPill');
  icon.textContent = ok ? '✓' : '✗';
  icon.style.color = ok ? 'var(--green)' : 'var(--red)';
  box.style.borderColor = ok ? 'var(--green)' : 'var(--red)';
  box.style.background = ok ? 'rgba(30,215,96,0.05)' : 'rgba(230,51,31,0.05)';
  pill.className = 'status-pill ' + (ok ? 'sp-ok' : 'sp-fail');
  pill.textContent = (isSpine ? 'Spine ' : 'Eyes ') + (ok ? '✓' : '✗');
}

function drawVisuals() {
  const canvas = document.getElementById('camCanvas');
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  if (latestFace?.multiFaceLandmarks?.[0]) {
    const lm = latestFace.multiFaceLandmarks[0];
    const color = eyesOk ? '#1ed760' : '#e6331f';
    [33,133,160,153,362,263,385,373].forEach(i => {
      ctx.fillStyle = color;
      ctx.beginPath();
      ctx.arc(lm[i].x*canvas.width, lm[i].y*canvas.height, 2, 0, Math.PI*2);
      ctx.fill();
    });
  }
  if (latestPose?.poseLandmarks) {
    const lm = latestPose.poseLandmarks;
    const color = spineOk ? '#1ed760' : '#e6331f';
    [0,11,12].forEach(i => {
      ctx.fillStyle = color;
      ctx.beginPath();
      ctx.arc(lm[i].x*canvas.width, lm[i].y*canvas.height, 4, 0, Math.PI*2);
      ctx.fill();
    });
    ctx.strokeStyle = color; ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(lm[11].x*canvas.width, lm[11].y*canvas.height);
    ctx.lineTo(lm[12].x*canvas.width, lm[12].y*canvas.height);
    ctx.stroke();
  }
}

function toggleSess() {
  sessActive = !sessActive;
  const btn = document.getElementById('sessBtn');
  if (sessActive) {
    btn.textContent = 'Stop session';
    btn.style.background = 'var(--bg3)';
    addLog('Session started. Sit erect, eyes closed.');
    sessTimer = setInterval(() => {
      sessElapsed++;
      const m = Math.floor(sessElapsed/60), s = sessElapsed%60;
      document.getElementById('timerDisp').textContent = String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
      document.getElementById('timerDisp').className = 'timer-big' + (spineOk&&eyesOk ? ' counting' : '');
      document.getElementById('timerLbl').textContent = spineOk&&eyesOk ? 'Verified — minting $MONK' : 'Paused — fix posture or close eyes';
      if (spineOk && eyesOk) {
        consec++;
        // Award every second
        document.getElementById('progFill').style.width = '100%';
        document.getElementById('progFill').className = 'prog-fill earn';
        document.getElementById('progNum').textContent = 'MINTING LIVE';
        awardPoint();  // Award every second!
      } else {
        if (consec > 0) { consec = 0; addLog('Posture lost. Counter reset.'); }
        document.getElementById('progFill').style.width = '0%';
        document.getElementById('progFill').className = 'prog-fill';
        document.getElementById('progNum').textContent = 'PAUSED';
      }
    }, 1000);
  } else {
    clearInterval(sessTimer);
    btn.textContent = 'Start session';
    btn.style.background = 'var(--red)';
    document.getElementById('medBanner').classList.remove('on');
    document.getElementById('camGlow').classList.remove('on');
    addLog('Session ended — ' + totalPts + ' total $MONK minted.');
  }
}

function awardPoint() {
  totalPts += 1;  // Award 1 MONK every second
  localStorage.setItem('mmga_pts', totalPts);
  document.getElementById('modalPts').textContent = totalPts;
  addLog('★ +1 $MONK! Total: ' + totalPts);
  const p = document.getElementById('pointPop');
  p.textContent = '+1 $MONK MINTED ★ (Total: ' + totalPts + ')';
  p.classList.add('on');
  setTimeout(() => p.classList.remove('on'), 2500);
  const ptEl = document.querySelector('.n-pts');
  if (ptEl) ptEl.textContent = '★ ' + totalPts + ' $MONK';
  if (window._supa && window._user) {
    window._supa.from('monk_points').upsert({user_id:window._user.id, email:window._user.email, points:totalPts, updated_at:new Date().toISOString()},{onConflict:'user_id'}).then(()=>{}).catch(()=>{});
  }
}

function resetSess() {
  clearInterval(sessTimer);
  sessActive = false; sessElapsed = 0; consec = 0;
  document.getElementById('sessBtn').textContent = 'Start session';
  document.getElementById('sessBtn').style.background = 'var(--red)';
  document.getElementById('timerDisp').textContent = '00:00';
  document.getElementById('timerDisp').className = 'timer-big';
  document.getElementById('timerLbl').textContent = 'Not started';
  document.getElementById('progFill').style.width = '0%';
  document.getElementById('progNum').textContent = '0 / 60s';
  document.getElementById('medBanner').classList.remove('on');
  document.getElementById('camGlow').classList.remove('on');
  document.getElementById('sessLog').innerHTML = '';
}

function addLog(msg) {
  const log = document.getElementById('sessLog');
  const t = new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  log.innerHTML = '<div>[' + t + '] ' + msg + '</div>' + log.innerHTML;
}

