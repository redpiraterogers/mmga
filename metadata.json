const SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFqb3pybnNvZXl2Y2JjeHlkaWV3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc2MjExNzcsImV4cCI6MjA5MzE5NzE3N30.dQ_n8CU_XPN9R2yYkUN30z4eexJUfpXKPABLtEawNDI';
