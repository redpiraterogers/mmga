function openAuth() {
  document.getElementById('authModal').classList.add('open');
  document.body.style.overflow = 'hidden';
  if(document.getElementById('authEmailStep')) document.getElementById('authEmailStep').style.display = 'block';
  if(document.getElementById('authCheckEmail')) document.getElementById('authCheckEmail').style.display = 'none';
  if(document.getElementById('authMsg')){
    document.getElementById('authMsg').textContent = '';
    document.getElementById('authMsg').className = 'auth-msg';
  }
  setTimeout(() => document.getElementById('authEmail')?.focus(), 100);
}
function closeAuth() {
  const authModal = document.getElementById('authModal');
  if (authModal) {
    authModal.classList.remove('open');
    document.body.style.overflow = '';
  }
}

async function sendMagicLink() {
  const email = document.getElementById('authEmail').value.trim();
  if (!email || !email.includes('@')) { showMsg('Enter a valid email.','err'); return; }
  const btn = document.getElementById('authSendBtn');
  btn.disabled = true; btn.textContent = 'Sending…';
  if (!window._supa) { showMsg('Auth not configured.','err'); btn.disabled=false; btn.textContent='Send magic link →'; return; }
  const {error} = await window._supa.auth.signInWithOtp({email, options:{emailRedirectTo:window.location.href}});
  if (error) { showMsg(error.message,'err'); btn.disabled=false; btn.textContent='Send magic link →'; }
  else { document.getElementById('authEmailSent').textContent=email; document.getElementById('authEmailStep').style.display='none'; document.getElementById('authCheckEmail').style.display='block'; }
}

async function signOut() {
  if (window._supa) await window._supa.auth.signOut();
  handleLoggedOut();
}
function showMsg(m,t){ const el=document.getElementById('authMsg'); if(el){el.textContent=m; el.className='auth-msg '+t;} }

function handleLoggedIn(user) {
  window._user = user;
  closeAuth();
  if(document.getElementById('guestBanner')) document.getElementById('guestBanner').style.display = 'none';
  const name = (user.email||'Monk').split('@')[0];
  document.getElementById('navRight').innerHTML =
    '<div class="n-user"><span class="n-pts">★ '+totalPts+' $MONK</span><span style="font-size:7px;color:var(--muted)">'+name+'</span></div>' +
    '<button onclick="document.getElementById(\'mmga-mint-widget\').scrollIntoView({behavior:\'smooth\'})" class="btn btn-red btn-sm">▶ Mint</button>' +
    '<button onclick="signOut()" class="n-signout">Sign out</button>';
  if (window._supa) {
    window._supa.from('monk_points').select('points').eq('user_id',user.id).single()
      .then(({data}) => { if(data?.points){ totalPts=data.points; localStorage.setItem('mmga_pts',totalPts); document.getElementById('modalPts').textContent=totalPts; const pt=document.querySelector('.n-pts'); if(pt) pt.textContent='★ '+totalPts+' $MONK'; }})
      .catch(()=>{});
  }
}
function handleLoggedOut() {
  window._user = null;
  document.getElementById('navRight').innerHTML =
    '<button id="nav-wallet-btn" class="n-cta" onclick="window.connectWallet()">Connect Wallet</button>' +
    '<div id="nav-wallet-connected" style="display:none;font-family:var(--mono);font-size:11px;color:var(--yellow);padding:8px 16px;background:rgba(255,215,0,0.1);border:2px solid rgba(255,215,0,0.3);border-radius:4px;"><span id="nav-wallet-address"></span></div>';
  if (typeof updateNavWallet === 'function') updateNavWallet();
}

/* ESC */
document.addEventListener('keydown', e => { if(e.key==='Escape'){ closeCam(); closeAuth(); }});
</script>

<script>
// Attach Begin button handler when DOM is ready
document.addEventListener('DOMContentLoaded', function() {
  const beginBtn = document.getElementById('begin-btn');
  if (beginBtn) {
    beginBtn.addEventListener('click', function() {
      console.log('Begin button clicked!');
      const modal = document.getElementById('camModal');
      if (modal) {
        modal.classList.add('open');
        document.body.style.overflow = 'hidden';
        console.log('Camera modal opened');
      } else {
        console.error('camModal not found!');
      }
    });
    console.log('Begin button handler attached');
  } else {
    console.error('begin-btn not found!');
  }
  
  // Also attach to hero Begin button
  const heroBeginBtn = document.getElementById('hero-begin-btn');
  if (heroBeginBtn) {
    heroBeginBtn.addEventListener('click', function() {
      console.log('Hero Begin button clicked!');
      const modal = document.getElementById('camModal');
      if (modal) {
        modal.classList.add('open');
        document.body.style.overflow = 'hidden';
        console.log('Camera modal opened from hero');
      } else {
        console.error('camModal not found!');
      }
    });
    console.log('Hero Begin button handler attached');
  }
});

// Camera modal functions
function openCam() {
  const modal = document.getElementById('camModal');
  if (modal) {
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
    // Initialize camera
    startCam();
  }
}

function closeCam() {
  const modal = document.getElementById('camModal');
  if (modal) {
    modal.classList.remove('open');
    document.body.style.overflow = '';
    if (typeof sessActive !== 'undefined' && sessActive) toggleSess();
    
    // FIX: Stop camera processing loop and release camera hardware properly
    // to prevent camera locks from causing permission errors next time it opens.
    if (typeof camLoopActive !== 'undefined') camLoopActive = false;
    if (typeof localStream !== 'undefined' && localStream) {
      localStream.getTracks().forEach(track => track.stop());
      const videoEl = document.getElementById('camVideo');
      if (videoEl) videoEl.srcObject = null;
    }
    
    // Sync locally earned MONK to backend if wallet is connected
    if (window.solana && window.solana.isConnected) {
      const localPoints = parseInt(localStorage.getItem('mmga_pts') || '0');
      if (localPoints > 0 && window.mmgaReloadBalance) {
        console.log('Camera closed, syncing earned MONK to wallet...');
        setTimeout(() => {
          window.mmgaReloadBalance(); // This will trigger loadBalance which syncs
        }, 500);
      }
    }
  }
}
</script>

<script>
/* WALLET CONNECTION & MINT WIDGET LOGIC */
let walletAddress = null;

function updateNavWallet() {
  const btn = document.getElementById('nav-wallet-btn');
  const connected = document.getElementById('nav-wallet-connected');
  const address = document.getElementById('nav-wallet-address');
  
  // Wallet Section UI logic
  if (window.solana && window.solana.isConnected && walletAddress) {
    const short = walletAddress.slice(0, 4) + '...' + walletAddress.slice(-4);
    
    // Update top nav
    if (address) address.textContent = '🔗 ' + short;
    if (btn) btn.style.display = 'none';
    if (connected) connected.style.display = 'block';
    
    // Update Mint Widget UI
    const mintSection = document.getElementById('mmga-wallet-section');
    const mintControls = document.getElementById('mint-controls');
    const mintBtn = document.getElementById('mint-btn');
    if (mintSection) mintSection.style.display = 'none';
    if (mintControls) mintControls.style.display = 'block';
    if (mintBtn) mintBtn.style.display = 'block';
    
  } else {
    // Top nav reset
    if (btn) btn.style.display = 'inline-block';
    if (connected) connected.style.display = 'none';
    
    // Mint Widget reset
    const mintSection = document.getElementById('mmga-wallet-section');
    const mintControls = document.getElementById('mint-controls');
    const mintBtn = document.getElementById('mint-btn');
    if (mintSection) mintSection.style.display = 'block';
    if (mintControls) mintControls.style.display = 'none';
    if (mintBtn) mintBtn.style.display = 'none';
  }
}

async function connectWallet() {
  if (!window.solana) {
    const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
    if(isMobile){
        const deepLink = 'https://phantom.app/ul/v1/connect?app_url=' + encodeURIComponent(window.location.href) + '&cluster=mainnet-beta';
        window.location.href = deepLink;
    } else {
        alert('Please install the Phantom wallet extension to connect.');
        window.open('https://phantom.app/', '_blank');
    }
    return;
  }

  try {
    await window.solana.connect();
    walletAddress = window.solana.publicKey.toString();
    updateNavWallet();
  } catch (error) {
    console.error('Connection error:', error);
  }
}

// Map functions to window for global inline onclick access
window.navConnectWallet = connectWallet;
window.connectWallet = connectWallet;

// Check wallet on initial load
window.addEventListener('load', () => {
  if (window.solana) {
    window.solana.on('connect', () => {
      walletAddress = window.solana.publicKey.toString();
      updateNavWallet();
    });
    
    window.solana.on('disconnect', () => {
      walletAddress = null;
      updateNavWallet();
    });
    
    if (window.solana.isConnected) {
      walletAddress = window.solana.publicKey.toString();
      updateNavWallet();
    }
  }
});

// Helper logic for Minting Widget (increment/decrement amounts)
function incrementAmount() {
  const input = document.getElementById('mint-amount');
  if (input && parseInt(input.value) < 100) {
    input.value = parseInt(input.value) + 1;
    document.getElementById('mint-btn-amount').textContent = input.value;
  }
}

function decrementAmount() {
  const input = document.getElementById('mint-amount');
  if (input && parseInt(input.value) > 1) {
    input.value = parseInt(input.value) - 1;
    document.getElementById('mint-btn-amount').textContent = input.value;
  }
}

function mintToken() {
   const amount = document.getElementById('mint-amount').value;
   const msgSection = document.getElementById('mmga-message-section');
   
   if (msgSection) {
     msgSection.innerHTML = `<div style="color:var(--yellow);padding:10px;border:1px solid var(--yellow);text-align:center;">Initiating mint for ${amount} $MONK... Please approve transaction in your wallet.</div>`;
     
     // Mock Mint response wait time
     setTimeout(() => {
       msgSection.innerHTML = `<div style="color:var(--green);padding:10px;border:1px solid var(--green);text-align:center;">Successfully minted ${amount} $MONK! Transaction confirmed.</div>`;
     }, 2500);
   }
}
</script>
</body>
</html>
